# ============================================
#  UNO Multiplayer Arena — Environment Config
#  Copy to .env and edit as needed.
# ============================================

# Server
PORT=3001
NODE_ENV=development
DB_PATH=./backend/db/uno.db
TURN_TIMER=30

# Frontend (used by Vite during build)
VITE_PORT=5173
VITE_API_URL=http://localhost:3001

# CORS (dev only — in production same-origin, so ignored)
FRONTEND_URL=http://localhost:5173
